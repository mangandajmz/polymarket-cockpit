# ── Polymarket Bot Dashboard — Environment Variables ──────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Password to access the dashboard (pick something strong)
DASHBOARD_PASSWORD=changeme

# Absolute path to paper_trades.csv on your VPS
# Example Linux path:
CSV_PATH=/home/ubuntu/polymarket-bot/paper_trades.csv

# Absolute path to bot.log on your VPS
LOG_PATH=/home/ubuntu/polymarket-bot/bot.log

# Auto-refresh interval in milliseconds (default 30 seconds)
REFRESH_MS=30000

# Daily cap in USD (must match bot config)
DAILY_CAP=60.0

# Starting bankroll in USD (must match bot config)
STARTING_BANKROLL=300.0

# Bot mode badge: PAPER or LIVE
BOT_MODE=PAPER
