# Polymarket Bot - Local Environment Variables
# Copy this file to .env and adjust values for your local machine.
# NEVER commit .env to git.

# Optional password for the local Streamlit dashboard.
# Leave blank for passwordless localhost access.
DASHBOARD_PASSWORD=

# Local runtime file paths. Relative paths stay inside this project folder.
CSV_PATH=paper_trades.csv
LOG_PATH=bot.log
STATE_DB_PATH=bot_state.db

# Auto-refresh interval in milliseconds.
REFRESH_MS=30000

# Daily net resolved loss cap in USD. This is not a total daily spend cap.
DAILY_LOSS_CAP=60.0

# Starting simulated bankroll in USD.
STARTING_BANKROLL=300.0

# Shadow-model veto threshold for copied heuristic trades.
HYBRID_VETO_THRESHOLD=0.65

# Bot mode badge shown in the dashboard.
BOT_MODE=PAPER
